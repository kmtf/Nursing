<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nursing Master 2.0 - למידה ללא הגבלה</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;600;700&display=swap');
        body {
            font-family: 'Assistant', sans-serif;
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            min-height: 100vh;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        .option-btn {
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            text-align: right;
            border-width: 2px;
        }
        .option-btn:hover:not(:disabled) {
            transform: translateX(-5px);
            border-color: #3b82f6;
            background-color: #eff6ff;
        }
        .correct-opt {
            background-color: #dcfce7 !important;
            border-color: #22c55e !important;
            color: #166534 !important;
        }
        .wrong-opt {
            background-color: #fee2e2 !important;
            border-color: #ef4444 !important;
            color: #991b1b !important;
        }
        .animate-pop {
            animation: pop 0.4s cubic-bezier(0.26, 0.53, 0.74, 1.48);
        }
        @keyframes pop {
            0% { opacity: 0; transform: scale(0.9); }
            100% { opacity: 1; transform: scale(1); }
        }
    </style>
</head>
<body class="p-4 md:p-8 flex items-center justify-center">

    <div id="game-container" class="max-w-4xl w-full glass-card rounded-[2.5rem] shadow-2xl overflow-hidden flex flex-col min-h-[750px]">
        
        <!-- Top Bar -->
        <div class="bg-slate-800 p-6 text-white flex justify-between items-center shadow-lg">
            <div class="flex items-center gap-3">
                <i class="fas fa-stethoscope text-2xl text-blue-400"></i>
                <div>
                    <h1 class="text-xl font-bold leading-tight">Nursing Master 2.0</h1>
                    <p class="text-xs opacity-70">מרתון סיעוד המבוגר 1 • ללא הגבלת פסילות</p>
                </div>
            </div>
            <div class="flex items-center gap-8">
                <div class="text-center">
                    <p class="text-[10px] uppercase opacity-60">הצלחות</p>
                    <p id="stats-correct-top" class="text-xl font-bold text-emerald-400">0</p>
                </div>
                <div class="text-center">
                    <p class="text-[10px] uppercase opacity-60">טעויות</p>
                    <p id="stats-wrong-top" class="text-xl font-bold text-rose-400">0</p>
                </div>
            </div>
        </div>

        <!-- Progress Bar -->
        <div class="w-full bg-slate-200 h-1.5">
            <div id="progress-bar" class="bg-blue-600 h-full w-0 transition-all duration-500"></div>
        </div>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col p-6 md:p-10 relative">
            
            <!-- Welcome Screen -->
            <div id="screen-welcome" class="flex-1 flex flex-col items-center justify-center text-center">
                <div class="w-32 h-32 bg-blue-50 rounded-full flex items-center justify-center mb-8 shadow-inner">
                    <i class="fas fa-graduation-cap text-6xl text-blue-600"></i>
                </div>
                <h2 class="text-4xl font-black text-slate-800 mb-6">ברוכים הבאים למרתון המומחה</h2>
                <p class="text-xl text-slate-600 mb-10 max-w-xl leading-relaxed">
                    לפניך 20 שאלות המקיפות את כל החומר הנלמד. 
                    בגרסה זו אין הגבלת פסילות – המטרה היא ללמוד מהרציונל של כל תשובה עד לסיום המבחן.
                </p>
                <button onclick="startGame()" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-5 px-20 rounded-2xl shadow-xl hover:shadow-blue-200 transition-all active:scale-95 text-2xl">
                    התחל למידה
                </button>
            </div>

            <!-- Quiz Screen -->
            <div id="screen-quiz" class="hidden flex-1 flex flex-col">
                <div class="mb-4">
                    <span id="question-label" class="text-sm font-bold text-blue-600 bg-blue-50 px-4 py-1.5 rounded-full">שאלה 1 מתוך 20</span>
                </div>
                
                <h3 id="question-body" class="text-2xl font-bold text-slate-800 mb-8 leading-snug">
                    שאלה טוענת...
                </h3>

                <div id="options-grid" class="space-y-3 flex-1">
                    <!-- Options injected here -->
                </div>

                <!-- Feedback Section (Hidden initially) -->
                <div id="feedback-area" class="hidden mt-8 animate-pop border-t border-slate-100 pt-8">
                    <div class="flex items-center gap-4 mb-6">
                        <div id="feedback-indicator" class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl"></div>
                        <div>
                            <h4 id="feedback-msg" class="text-2xl font-black"></h4>
                            <p class="text-slate-500 text-sm font-semibold">ניתוח קליני מפורט:</p>
                        </div>
                    </div>
                    
                    <div class="bg-slate-50 p-6 rounded-2xl border-r-8 border-slate-300 shadow-inner mb-8">
                        <p id="feedback-rationale" class="text-slate-700 text-lg italic leading-relaxed"></p>
                    </div>

                    <button onclick="nextStep()" class="w-full bg-slate-800 hover:bg-black text-white font-bold py-5 rounded-2xl text-xl transition-all shadow-lg">
                        המשך לשאלה הבאה
                    </button>
                </div>
            </div>

            <!-- Summary Screen -->
            <div id="screen-summary" class="hidden flex-1 flex flex-col items-center justify-center text-center">
                <div id="final-visual" class="text-8xl mb-8"></div>
                <h2 class="text-4xl font-black text-slate-800 mb-2">סיכום המרתון</h2>
                <p id="final-text" class="text-xl text-slate-600 mb-12"></p>
                
                <div class="grid grid-cols-2 gap-6 w-full max-w-md mb-12">
                    <div class="bg-emerald-50 p-6 rounded-3xl border border-emerald-100">
                        <p class="text-xs text-emerald-600 font-bold uppercase mb-1">דיוק קליני</p>
                        <p id="final-correct" class="text-4xl font-black text-emerald-600">0</p>
                    </div>
                    <div class="bg-rose-50 p-6 rounded-3xl border border-rose-100">
                        <p class="text-xs text-rose-600 font-bold uppercase mb-1">טעויות ללמידה</p>
                        <p id="final-wrong" class="text-4xl font-black text-rose-600">0</p>
                    </div>
                </div>

                <button onclick="location.reload()" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-5 px-16 rounded-2xl text-xl shadow-xl transition-all">
                    תרגול חוזר
                </button>
            </div>

        </main>
    </div>

    <script>
        const database = [
            {
                q: "מטופל עם אי-ספיקת כליות מציג ערכי גזים: pH=7.18, CO2=40, HCO3=15. מהי האבחנה?",
                options: ["חמצת מטבולית ללא פיצוי", "חמצת נשימתית בפיצוי חלקי", "בססת מטבולית בפיצוי נשימתי", "חמצת משולבת"],
                correct: 0,
                r: "ה-pH והביקרבונט נמוכים (חמצת מטבולית), וה-CO2 בטווח התקין, מה שמעיד על כך שהריאות טרם החלו לפצות."
            },
            {
                q: "במהלך שלב 0 של פוטנציאל הפעולה בלב, איזה תהליך אלקטרוליטרי מתרחש?",
                options: ["כניסה מהירה של נתרן (Na+)", "יציאה של אשלגן (K+)", "כניסה איטית של סידן (Ca2+)", "פתיחת תעלות מגנזיום"],
                correct: 0,
                r: "שלב 0 הוא הדה-פולריזציה המהירה הנגרמת מכניסה מאסיבית של נתרן לתא, מה שיוצר את קומפלקס ה-QRS."
            },
            {
                q: "מטופלת עם שחמת מציגה רעד 'כנפיים' (Asterixis). באיזה שלב של אנצפלופתיה כבדית היא נמצאת?",
                options: ["שלב 1", "שלב 2", "שלב 3", "שלב 4"],
                correct: 1,
                r: "שלב 2 מתאפיין בבלבול בולט והופעת ה-Asterixis (Flapping tremor). זכור: ציפור עם 2 כנפיים = שלב 2."
            },
            {
                q: "מהו הממצא ב-EKG המעיד על היפרקלמיה (אשלגן גבוה) מסכנת חיים?",
                options: ["הופעת גלי U בולטים", "גלי T מחודדים וגבוהים והתרחבות QRS", "קיצור מרווח ה-PR", "צניחות מקטע ST"],
                correct: 1,
                r: "אשלגן גבוה מאיץ את הר-פולריזציה (גלי T מחודדים) ומעכב הולכה בחדרים (QRS רחב), מה שמבשר דום לב."
            },
            {
                q: "מהו הרציונל למתן Lactulose (אבולק) באנצפלופתיה כבדית?",
                options: ["הפיכת סביבת המעי לחומצית ללכידת אמוניה והפרשתה", "שיפור זרימת הדם לכבד", "העלאת רמת האשלגן בדם", "דיכוי ייצור בילירובין"],
                correct: 0,
                r: "הלטולוז הופך אמוניה ליון אמוניום שאינו נספג בדם ומפונה בצואה. הסיסמה: Lactulose = Loose stool = Lower ammonia."
            },
            {
                q: "מטופל עם אי-ספיקת לב ימנית ו-CVP של 15. איזה סימן קליני תצפה לראות?",
                options: ["חרחורים בריאות", "גודש וורידי צוואר (JVD) ובצקות פריפריות", "קצף ורדרד מהפה", "לחץ דם ריאתי נמוך מאוד"],
                correct: 1,
                r: "כשל ימני גורם לדם 'להיתקע' לפני הלב, מה שמתבטא בגודש ורידי סיסטמי (JVD) ובצקות ברגליים ובאיברים."
            },
            {
                q: "בשלב 2 של פוטנציאל הפעולה (Plateau), איזה יון נכנס לתא ואיך זה נראה ב-EKG?",
                options: ["נתרן (Na+); קומפלקס QRS", "סידן (Ca2+); מקטע ST", "אשלגן (K+); גל T", "כלור (Cl-); גל P"],
                correct: 1,
                r: "כניסת סידן איטית מאזנת יציאת אשלגן ויוצרת את שלב הפלאטו (התכווצות מכנית), המיוצג ע\"י מקטע ST."
            },
            {
                q: "מהי הסכנה בביצוע Suction (שאיבת הפרשות) ממושך מדי?",
                options: ["גרימת בססת מטבולית", "גירוי עצב הוואגוס המוביל לברדיקרדיה", "עלייה בלחץ הדם הורידי", "פגיעה בתפוקת הכליות"],
                correct: 1,
                r: "שאיבה ממושכת או אגרסיבית מדי מגרה את המערכת הפארא-סימפתטית (וואגוס) ועלולה לגרום לצניחת דופק מסוכנת."
            },
            {
                q: "מדוע בקרדיומיופתיה היפרטרופית (HCM) אסור לתת Digoxin?",
                options: ["הוא מרחיב כלי דם בקיצוניות", "חיזוק ההתכווצות מחמיר את החסימה במוצא הלב", "הוא גורם לעלייה ברמת האמוניה", "הוא גורם לאיבוד סידן מהתאים"],
                correct: 1,
                r: "ב-HCM השריר מעובה. הגברת עוצמת הכיווץ (אינוטרופיות) גורמת לשריר לחסום את נתיב יציאת הדם מהלב."
            },
            {
                q: "מה קורה ב-Dilated Cardiomyopathy (DCM)?",
                options: ["השריר הופך למעובה וקשיח", "החדרים מתרחבים והשריר נהיה חלש (פגיעה סיסטולית)", "המסתם המיטרלי הופך למוצר", "רמת האשלגן בתאים עולה"],
                correct: 1,
                r: "ב-DCM הלב מתרחב משמעותית והיכולת שלו להתכווץ (EF) נפגעת קשות. הלב נראה 'סמרטוטי'."
            },
            {
                q: "מהו 'מבחן אלן' (Allen's Test) ולמה הוא משמש?",
                options: ["בדיקת רגישות לכאב", "בדיקת זרימת דם קולטרלית מהעורק האולנרי לפני דקירת רדיאלי", "אומדן רמת הבלבול", "בדיקת תפקוד המסתמים ברגליים"],
                correct: 1,
                r: "המבחן מוודא שיש אספקת דם ליד במקרה שהעורק הרדיאלי ייפגע או ייחסם במהלך לקיחת גזים בדם."
            },
            {
                q: "מטופל עם COPD מאוזן מציג PCO2=55 ו-pH תקין. איך זה אפשרי?",
                options: ["הוא נושם מהר מאוד (היפרוונטילציה)", "הכליות ביצעו פיצוי מטבולי על ידי שמירת ביקרבונט", "הוא מקבל חמצן בלחץ גבוה", "זו טעות מעבדה"],
                correct: 1,
                r: "במצבי COPD כרוניים, הכליות שומרות ביקרבונט (בסיס) לאורך זמן כדי לאזן את החומצה הנשימתית."
            },
            {
                q: "מהו הסיבוך המיידי הנפוץ ביותר לאחר Thoracentesis?",
                options: ["חזה אוויר (Pneumothorax)", "עלייה פתאומית בלחץ דם", "זיהום חיידקי בדם", "עצירות כרונית"],
                correct: 0,
                r: "דקירה מקרית של הריאה על ידי המחט עלולה לגרום לדליפת אוויר וקריסת הריאה. חובה לבצע צילום חזה."
            },
            {
                q: "איזו אבחנה סיעודית בעדיפות עליונה בחמצת מטבולית קשה (pH=7.15)?",
                options: ["חוסר ידע לגבי המחלה", "פגיעה בחילוף גזים ומאזן חומצה-בסיס", "שינוי בדפוס השינה", "סיכון לפגיעה בשלמות העור"],
                correct: 1,
                r: "חמצת קשה משפיעה על כל אנזימי הגוף ועלולה להוביל לקריסה המודינמית. זהו המצב המסוכן ביותר לחיים."
            },
            {
                q: "מה מייצג גל T ב-EKG ואיזה אלקטרוליט אחראי עליו?",
                options: ["דה-פולריזציה; נתרן", "ר-פולריזציה; אשלגן (K+)", "פלאטו; סידן", "מנוחה; מגנזיום"],
                correct: 1,
                r: "גל T מייצג את שלב ה'טעינה מחדש' (ר-פולריזציה) ונוצר בעיקר מיציאת אשלגן מהתא (שלב 3)."
            },
            {
                q: "מדוע דימום במערכת העיכול מסוכן לחולה כבד (מעבר לאובדן הדם)?",
                options: ["הדם גורם לעלייה ברמת הסוכר", "פירוק הדם במעי מעלה את רמת האמוניה בדם", "הדם גורם לבצקת ריאות", "הדם סותר את תרופת הדיגוקסין"],
                correct: 1,
                r: "דם הוא חלבון. חיידקי המעי מפרקים אותו ומייצרים אמוניה בכמות גדולה, מה שעלול לגרום לתרדמת כבדית."
            },
            {
                q: "מה קורה ב-Mitral Regurgitation (MR)?",
                options: ["דם דולף מהחדר לעלייה שמאלית בזמן הסיסטולה", "הפתח בין העלייה לחדר מוצר מאוד", "אין זרימת דם לריאות", "לחץ הדם בעורקים נהיה גבוה מדי"],
                correct: 0,
                r: "ב-MR המסתם לא נסגר. בזמן התכווצות (סיסטולה) הדם דולף אחורה לעלייה ומקרין לאקסילה (בית השחי)."
            },
            {
                q: "איך נותנים אשלגן (KCl) לווריד בצורה בטוחה?",
                options: ["בדחיפה מהירה (Push)", "מהול בתוך שקית נוזלים ובעירוי איטי בלבד", "ישירות לעורק הרדיאלי", "רק אם המטופל בהכרה מלאה"],
                correct: 1,
                r: "מתן אשלגן בדחיפה (Push) הוא קטלני! הוא עוצר את הלב מיידית. חובה לתת מדולל ובקצב מבוקר."
            },
            {
                q: "מהו הסימן המוקדם ביותר ב-EKG להיפוקלמיה (אשלגן נמוך)?",
                options: ["גלי T גבוהים", "הופעת גלי U וצניחות מקטע ST", "התרחבות QRS", "היעלמות גלי P"],
                correct: 1,
                r: "חוסר אשלגן מעכב את הר-פולריזציה וגורם להופעת גל U בולט אחרי גל T ושינויים במקטע ST."
            },
            {
                q: "מהי הסכנה במתן 100% חמצן לחולה COPD עם היפוקסמיה כרונית?",
                options: ["דיכוי דחף הנשימה וצבירת CO2 (נרקוזה)", "עלייה חריפה ברמת האמוניה", "התפתחות מיידית של סוכרת", "נזק קבוע לשמיעה"],
                correct: 0,
                r: "חולי COPD נושמים בגלל חוסר חמצן (Hypoxic Drive). מתן עודף חמצן 'מכבה' את המנגנון הזה וגורם לעצירת נשימה."
            }
        ];

        let state = {
            current: 0,
            correct: 0,
            wrong: 0,
            answered: false
        };

        function startGame() {
            document.getElementById('screen-welcome').classList.add('hidden');
            document.getElementById('screen-quiz').classList.remove('hidden');
            renderQuestion();
        }

        function renderQuestion() {
            if (state.current >= database.length) {
                showSummary();
                return;
            }

            state.answered = false;
            const qData = database[state.current];
            document.getElementById('question-label').innerText = `שאלה ${state.current + 1} מתוך ${database.length}`;
            document.getElementById('question-body').innerText = qData.q;
            document.getElementById('feedback-area').classList.add('hidden');
            document.getElementById('progress-bar').style.width = `${(state.current / database.length) * 100}%`;

            const grid = document.getElementById('options-grid');
            grid.innerHTML = '';

            qData.options.forEach((opt, i) => {
                const btn = document.createElement('button');
                btn.className = "option-btn w-full p-5 rounded-2xl bg-white border-2 border-slate-100 shadow-sm font-semibold text-slate-700 flex justify-between items-center group";
                btn.innerHTML = `<span>${opt}</span><i class="fas fa-chevron-left text-slate-300 group-hover:text-blue-500"></i>`;
                btn.onclick = () => selectOption(i, btn);
                grid.appendChild(btn);
            });
        }

        function selectOption(index, btnElement) {
            if (state.answered) return;
            state.answered = true;

            const qData = database[state.current];
            const isCorrect = index === qData.correct;
            const options = document.querySelectorAll('.option-btn');

            // Highlight answers
            options.forEach((btn, i) => {
                btn.disabled = true;
                if (i === qData.correct) btn.classList.add('correct-opt');
                if (i === index && !isCorrect) btn.classList.add('wrong-opt');
            });

            // Update stats
            if (isCorrect) {
                state.correct++;
                document.getElementById('stats-correct-top').innerText = state.correct;
                showFeedbackPanel(true, qData.r);
            } else {
                state.wrong++;
                document.getElementById('stats-wrong-top').innerText = state.wrong;
                showFeedbackPanel(false, qData.r);
            }
        }

        function showFeedbackPanel(isCorrect, rationale) {
            const panel = document.getElementById('feedback-area');
            const indicator = document.getElementById('feedback-indicator');
            const msg = document.getElementById('feedback-msg');
            const text = document.getElementById('feedback-rationale');

            panel.classList.remove('hidden');
            text.innerText = rationale;

            if (isCorrect) {
                indicator.className = "w-14 h-14 rounded-2xl flex items-center justify-center text-2xl bg-emerald-100 text-emerald-600";
                indicator.innerHTML = '<i class="fas fa-check"></i>';
                msg.innerText = "תשובה נכונה!";
                msg.className = "text-2xl font-black text-emerald-600";
            } else {
                indicator.className = "w-14 h-14 rounded-2xl flex items-center justify-center text-2xl bg-rose-100 text-rose-600";
                indicator.innerHTML = '<i class="fas fa-times"></i>';
                msg.innerText = "טעות קלינית";
                msg.className = "text-2xl font-black text-rose-600";
            }
        }

        function nextStep() {
            state.current++;
            renderQuestion();
        }

        function showSummary() {
            document.getElementById('screen-quiz').classList.add('hidden');
            document.getElementById('screen-summary').classList.remove('hidden');
            document.getElementById('progress-bar').style.width = "100%";

            const visual = document.getElementById('final-visual');
            const finalCorrect = document.getElementById('final-correct');
            const finalWrong = document.getElementById('final-wrong');
            const finalText = document.getElementById('final-text');

            finalCorrect.innerText = state.correct;
            finalWrong.innerText = state.wrong;

            if (state.correct >= 18) {
                visual.innerHTML = '<i class="fas fa-award text-yellow-500"></i>';
                finalText.innerText = "מדהים! אתה שולט בחומר בצורה מצוינת.";
            } else if (state.correct >= 14) {
                visual.innerHTML = '<i class="fas fa-thumbs-up text-blue-500"></i>';
                finalText.innerText = "עבודה טובה! ניכר שיש לך בסיס חזק.";
            } else {
                visual.innerHTML = '<i class="fas fa-book-reader text-slate-400"></i>';
                finalText.innerText = "מומלץ לעבור שוב על הרציונלים ולתרגל שוב.";
            }
        }
    </script>
</body>
</html>
